    <string name="shizuku_help_step1_title">Download Shizuku</string>
    <string name="shizuku_help_step1_desc">Download the Shizuku app from Google Play or GitHub\n\n• Google Play: Search \"Shizuku\"\n• GitHub: github.com/RikkaApps/Shizuku</string>
    <string name="shizuku_help_step2_title">Start Shizuku</string>
    <string name="shizuku_help_step2_desc">Open the Shizuku app and select the startup method according to your device:\n\n• Wireless debugging (recommended): Requires Android 11+, turn on wireless debugging in developer options\n• Connect to computer: Start via ADB command</string>
    <string name="shizuku_help_step3_title">Authorize Roubao</string>
    <string name="shizuku_help_step4_title">Get started</string>
    <string name="shizuku_help_step4_desc">After authorization is complete, return to the Roubao application and the status card will display "Shizuku is connected"</string>

    
    <string name="overlay_why">Why do I need floating window permission?</string>
    <string name="overlay_reason">When Roubao performs tasks, he needs to display a floating window to:</string>
    <string name="overlay_feature1">Show current execution progress</string>
    <string name="overlay_feature2">Provide a stop button to interrupt the task at any time</string>
    <string name="overlay_feature3">Show status information above other apps</string>
    <string name="overlay_how">How to turn it on?</string>
    <string name="overlay_how_desc">1. When you click to perform a task, you will be prompted automatically\n2. Or go to: Settings &gt; Applications &gt; Roubao &gt; Floating Window Permissions\n3. Turn on "Allow display on top of other applications"</string>
    <string name="overlay_privacy">Privacy and security</string>
    <string name="overlay_privacy_desc">The floating window is only displayed during task execution and does not collect any personal information. The floating window will automatically disappear after the task is completed.</string>

    
