    <string name="onboarding_ai_desc">Based on an advanced visual language model,\nRoubao is able to understand screen content and make intelligent decisions</string>
    <string name="onboarding_easy">Simple and easy to use</string>
    <string name="onboarding_easy_desc">Just describe what you want to do in natural language, and Roubao will automatically do it for you.</string>
    <string name="onboarding_safe">Safe and reliable</string>
    <string name="onboarding_safe_desc">It will automatically stop when encountering sensitive pages (such as payment, password),\nprotecting the security of your account</string>
